# ── LiveKit (livekit.com → project → Settings → Keys) ────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Google / Gemini Live ─────────────────────────────────────────────────────
# Gemini Live (speech-to-speech) uses a Gemini API key:
GOOGLE_API_KEY=
GEMINI_VOICE=Puck

# ── Vobiz SIP trunk (https://docs.vobiz.ai/platform/sip/overview) ─────────────
VOBIZ_SIP_HOST=sip.vobiz.ai
VOBIZ_PHONE_NUMBER=+9180XXXXXXXX
VOBIZ_USERNAME=
VOBIZ_PASSWORD=

# Filled in after running setup_trunks.py:
SIP_OUTBOUND_TRUNK_ID=

# ── App wiring ───────────────────────────────────────────────────────────────
# The deployed Next.js app whose /api/voice ingests reports.
APP_URL=https://samadhaan-822987556610.us-central1.run.app
# Must match WorkerOptions agent name + the Next.js NOTIFY_SECRET.
AGENT_NAME=samadhaan-voice
NOTIFY_SECRET=change-me-to-a-long-random-string
